# Copy this file to .env and edit the values.
# .env is gitignored — never commit real secrets.

# === MQTT credentials ===
# Username and password used by every MQTT client (sensors, services,
# students). After editing, run scripts/bootstrap-mqtt-passwd.sh to write
# the hashed copy Mosquitto reads.
MQTT_USER=platform
MQTT_PASSWORD=change-me-please

# === Anthropic / Claude API ===
# Leave ANTHROPIC_API_KEY blank for Phases 2-5 — the AI service falls back
# to a deterministic stub. Wire up a real key in Phase 6.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_OUTPUT_TOKENS=256
ANTHROPIC_TIMEOUT_S=15

# === Database ===
# SQLite file path inside the API container. The host bind mount is
# managed by docker-compose.yml; you should not normally need to change
# this.
DB_PATH=/data/sqlite/platform.db

# === Time zone ===
# Used by Node-RED and any service that logs local times.
TZ=Europe/Jersey
